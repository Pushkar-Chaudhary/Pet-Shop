# Gmail SMTP Configuration for Order Notifications
# Rename this file to '.env' and fill in your credentials.

# SMTP Server configuration (Default is Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Sender Email credentials
SMTP_USER=your-email@gmail.com
# For Gmail, you MUST use a 16-character App Password (not your normal password).
# How to get it: Google Account Settings -> Security -> 2-Step Verification -> App Passwords.
SMTP_PASS=your-gmail-app-password

# Recipient Email for Seller alerts. If left empty, it defaults to SMTP_USER.
SELLER_EMAIL=seller-email@gmail.com
